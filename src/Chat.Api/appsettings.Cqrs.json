{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DeploymentProfile": "Cqrs",
  "ConnectionStrings": {
    "ChatReadDb": "Host=localhost;Port=5432;Database=chat_read;Username=postgres;Password=postgres"
  },
  "CommandStore": {
    "Provider": "Mongo",
    "Mongo": {
      "ConnectionString": "mongodb://localhost:27017",
      "DatabaseName": "chat_commands"
    }
  },
  "ReadStore": {
    "Provider": "Postgres",
    "SchemaName": "ReadModel"
  },
  "EventBus": {
    "Strategy": "Postgres",
    "Postgres": {
      "ConnectionString": "Host=localhost;Port=5432;Database=chat_read;Username=postgres;Password=postgres",
      "TableName": "domain_events_outbox",
      "PollingInterval": 1,
      "BatchSize": 100
    }
  },
  "RabbitMq": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest"
  }
}
