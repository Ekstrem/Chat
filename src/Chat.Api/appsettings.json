{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ChatDb": "Host=localhost;Port=5432;Database=chat_events;Username=postgres;Password=postgres",
    "ChatReadDb": "Host=localhost;Port=5432;Database=chat_read;Username=postgres;Password=postgres"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest"
  },
  "EventBus": {
    "Strategy": "InMemory",
    "Kafka": {
      "BootstrapServers": "localhost:9092",
      "TopicPrefix": "chat-events",
      "GroupId": "chat-group"
    },
    "Postgres": {
      "ConnectionString": "Host=localhost;Port=5432;Database=chat_events;Username=postgres;Password=postgres",
      "TableName": "domain_events_outbox",
      "PollingInterval": 5,
      "BatchSize": 100
    }
  }
}
