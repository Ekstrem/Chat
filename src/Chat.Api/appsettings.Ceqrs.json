{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DeploymentProfile": "Ceqrs",
  "CommandStore": {
    "Provider": "Mongo",
    "Mongo": {
      "ConnectionString": "mongodb://localhost:27017",
      "DatabaseName": "chat_commands"
    }
  },
  "ReadStore": {
    "Provider": "Scylla",
    "Scylla": {
      "ContactPoints": ["scylla-node1"],
      "Keyspace": "chat_read",
      "TableName": "projections",
      "ReplicationFactor": 3,
      "AutoCreateSchema": true
    }
  },
  "EventBus": {
    "Strategy": "Kafka",
    "Kafka": {
      "BootstrapServers": "kafka:9092",
      "TopicPrefix": "chat-events",
      "GroupId": "chat-group"
    }
  },
  "RabbitMq": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest"
  }
}
